#pragma once

// secrets.h is no longer needed.
//
// WiFi credentials are now configured via the captive portal at first boot:
//   1. Power on the ESP32 with no saved credentials.
//   2. Connect your phone to the "PiStar-Setup" open WiFi network.
//   3. A configuration page opens automatically — enter your WiFi SSID and password.
//   4. The ESP32 saves credentials to NVS and restarts.
//
// Pi-Star IP is auto-discovered at runtime (NVS cache → mDNS → network scan).
// No hardcoded values are required.
//
// To reset saved WiFi credentials: hold the touchscreen at power-on for 3 seconds.
